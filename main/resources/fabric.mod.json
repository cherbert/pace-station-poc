  "authors": [
    "Chris"
  ],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.tinblue.spacemod.SpaceMod"
    ],
    "client": [
      "com.tinblue.spacemod.client.SpaceModClient"
    ]
  },
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*"
